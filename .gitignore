# Repository-local ignore config
.gitignore
# Local datasets and large artifacts
/data/*
!/data/
!/data/README.md
/weights/

/pretrained/*
!/pretrained/
!/pretrained/README.md

# Keep only public SHHA data-processing tools.
/tools/*
!/tools/
!/tools/prepare_shha.py
!/tools/README.md

# Keep only the public SHHA data config.
/configs/data/*
!/configs/data/
!/configs/data/shha.yaml

# Local scratch files
/README1.md
/matcher.py
/test.py
/mingling

# Asset hygiene
/assets/**/*.ckpt
/assets/**/*.pth
/assets/**/*.pt
/assets/**/*.npy
/assets/**/*.npz
# Python cache/artifacts
__pycache__/
*.py[cod]
*.so

# Tool caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
wandb/

# Virtual environments
.venv/
venv/
env/

# Logs and runtime outputs
logs/
runs/
ckpt/
outputs/
*.log
!/assets/logs/
!/assets/logs/train.log

# Editor/OS
.vscode/
.idea/
.DS_Store
